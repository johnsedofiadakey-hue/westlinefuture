VITE_FIREBASE_API_KEY=your_value_here
VITE_FIREBASE_AUTH_DOMAIN=your_value_here
VITE_FIREBASE_PROJECT_ID=your_value_here
VITE_FIREBASE_STORAGE_BUCKET=your_value_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_value_here
VITE_FIREBASE_APP_ID=your_value_here

# Local phone-auth testing only. When true in Vite dev mode, Firebase skips
# reCAPTCHA app verification for Firebase console test phone numbers.
# Never enable this for production builds.
VITE_FIREBASE_PHONE_AUTH_TEST_MODE=false

VITE_CLAUDE_API_KEY=your_key_here

# PAYMENTS (Paystack)
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_key_here

# SMS PROVIDER (options: arkesel, mock)
VITE_SMS_PROVIDER=arkesel

# META WHATSAPP CLOUD API (server-side only — keys live in Cloud Functions secrets)
# Set via: firebase functions:secrets:set META_WA_TOKEN
# Set via: firebase functions:secrets:set META_WA_PHONE_ID

# ARKESEL SMS (server-side only — key lives in Cloud Functions secrets)
# Set via: firebase functions:secrets:set ARKESEL_API_KEY

# Twilio removed — use Meta WhatsApp + Arkesel for all messaging
