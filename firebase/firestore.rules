rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Block all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      let isEmailAdmin = isAuthenticated() && "email" in request.auth.token && request.auth.token.email != null && (
        request.auth.token.email.matches(".*@westlinefuture.com") ||
        request.auth.token.email == "admin@westlinefuture.com"
      );
      let isRoleAdmin = userHasRole("admin") || userHasRole("staff");
      return isEmailAdmin || isRoleAdmin;
    }

    function tokenHasRole(role) {
      return isAuthenticated()
        && "role" in request.auth.token
        && request.auth.token.role == role;
    }

    function userHasRole(role) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isStaff() {
      return isAuthenticated() && (
        (
          "role" in request.auth.token &&
          request.auth.token.role in [
            "staff",
            "project manager",
            "project_manager",
            "finance manager",
            "operations manager"
          ]
        ) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in [
            "staff",
            "project manager",
            "project_manager",
            "finance manager",
            "operations manager"
          ]
        )
      );
    }

    function isWorker() {
      return tokenHasRole("worker") || userHasRole("worker");
    }

    function isAdminOrStaff() {
      return isAdmin() || isStaff();
    }

    function authPhoneId() {
      return isAuthenticated()
        && "phone_number" in request.auth.token
        && request.auth.token.phone_number != null
        ? request.auth.token.phone_number.replace("+", "")
        : "";
    }

    function authPhoneNumber() {
      return isAuthenticated()
        && "phone_number" in request.auth.token
        && request.auth.token.phone_number != null
        ? request.auth.token.phone_number
        : "";
    }

    function authEmail() {
      return isAuthenticated()
        && "email" in request.auth.token
        && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isClient(clientId) {
      return isAuthenticated() && (
        request.auth.uid == clientId ||
        authEmail().replace("@clients.westlinefuture.com", "") == clientId ||
        authPhoneNumber() == clientId ||
        authPhoneNumber() == ("+" + clientId) ||
        authPhoneId() == clientId
      );
    }

    // Check if the authenticated user is the client of a specific project.
    // Uses the project's clientIds array (multi-format) so phone-auth users
    // match regardless of whether the stored format has a "+" prefix or not.
    function isClientOfProject(projectId) {
      let d = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAuthenticated()
        && projectId is string
        && projectId.size() > 0
        && d != null
        && (
          isClient(d.clientId) ||
          (d.clientIds is list && request.auth.uid in d.clientIds) ||
          (d.clientIds is list && authPhoneId() in d.clientIds) ||
          (d.clientIds is list && authPhoneNumber() in d.clientIds)
        );
    }

    function isAssignedWorker(project) {
      return isWorker()
        && project.assignedWorkers is list
        && request.auth.uid in project.assignedWorkers;
    }

    function isAssignedStaff(project) {
      return isAuthenticated()
        && project.assignedStaff is list
        && request.auth.uid in project.assignedStaff;
    }

    function isAssignedClient(project) {
      return isClient(project.clientId)
        || (project.clientIds is list && request.auth.uid in project.clientIds)
        || (project.clientIds is list && authPhoneId() in project.clientIds)
        || (project.clientIds is list && authPhoneNumber() in project.clientIds);
    }

    function canReadProject(project) {
      return isAdminOrStaff()
        || isAssignedClient(project)
        || isAssignedWorker(project)
        || isAssignedStaff(project);
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow get: if isAdmin() || isClient(userId);
      allow list: if isAdmin();
      // Clients can update their own non-sensitive profile fields only
      allow update: if isAdmin() || (
        isClient(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'address', 'preferredPaymentMethod', 'onboarded', 'updatedAt'
        ])
      );
      allow create, delete: if isAdmin();
    }

    // --- UNIFIED CLIENT CHATS ---
    match /clients/{clientId} {
      allow read, write: if isAdmin() || isClient(clientId);

      match /{subcollection}/{docId} {
        allow read, write: if isAdmin() || isClient(clientId);
      }
    }

    match /team/{memberId} {
      allow read: if isAdminOrStaff() || (isAuthenticated() && request.auth.uid == memberId);
      allow write: if isAdmin();
    }

    // --- OPERATIONS: JOBS & ASSETS ---
    match /jobs/{jobId} {
      allow read: if isAdminOrStaff();
      allow write: if isAdminOrStaff();
    }
    match /assets/{assetId} {
      allow read: if isAdminOrStaff();
      allow write: if isAdminOrStaff();
    }

    // --- PROJECTS & CLIENT DATA ---
    match /projects/{projectId} {
      allow get, list: if canReadProject(resource.data);
      allow update: if isAdmin() || (
        isAssignedClient(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          // Rendering approval
          'renderingApproved', 'renderingApprovedAt',
          // Change requests
          'changeRequestPending',
          // Review
          'reviewDismissed', 'reviewDismissedAt', 'reviewSubmitted', 'reviewSubmittedAt'
        ])
      );
      allow create, delete: if isAdmin();

      match /messages/{msgId} {
        allow get, list: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create: if isAdminOrStaff()
          || isAssignedClient(get(/databases/$(database)/documents/projects/$(projectId)).data)
          || isAssignedWorker(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow update: if isAdminOrStaff()
          || (
            isAssignedClient(get(/databases/$(database)/documents/projects/$(projectId)).data)
            && resource.data.senderId == request.auth.uid
          );
        allow delete: if isAdmin();
      }
      // Typing presence — any authenticated participant can write their own doc
      match /typing/{typingUserId} {
        allow read: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow write: if (isAuthenticated() && request.auth.uid == typingUserId) || isAdmin();
        allow delete: if isAuthenticated();
      }
      match /documents/{docId} {
        allow get, list: if canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data)
          && (isAdminOrStaff() || resource.data.clientVisible == true || isAssignedWorker(get(/databases/$(database)/documents/projects/$(projectId)).data));
        allow create: if isAdminOrStaff()
          || (
            isAssignedWorker(get(/databases/$(database)/documents/projects/$(projectId)).data)
            && request.resource.data.uploadedByUid == request.auth.uid
          )
          || (
            isAssignedClient(get(/databases/$(database)/documents/projects/$(projectId)).data)
            && request.resource.data.uploadedByUid == request.auth.uid
          );
        allow update, delete: if isAdminOrStaff();
      }
      match /{subcollection}/{docId} {
        allow get, list: if subcollection != "documents" && canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create: if isAdminOrStaff() || (
          isAssignedWorker(get(/databases/$(database)/documents/projects/$(projectId)).data) &&
          subcollection in ["messages", "media", "notes"]
        ) || (
          isAssignedClient(get(/databases/$(database)/documents/projects/$(projectId)).data) &&
          subcollection in ["messages", "change_requests", "approvals"]
        );
        allow update: if isAdminOrStaff() || (
          subcollection == "messages" &&
          isAssignedClient(get(/databases/$(database)/documents/projects/$(projectId)).data) &&
          resource.data.senderId == request.auth.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "text", "editedAt", "editedBy", "editHistory", "updatedAt"
          ])
        );
        allow delete: if isAdmin();
      }
    }

    match /bookings/{bookingId} { allow read: if isAdmin(); allow create: if isAuthenticated(); }
    match /proposals/{proposalId} {
      allow read: if isAdmin() || isClient(resource.data.clientId);
      allow write: if isAdmin() || isClient(resource.data.clientId);
    }
    match /cms_content/{docId} {
      // Gateway settings contain public provider identifiers and feature flags
      // only. Secret credentials live exclusively in Secret Manager.
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /system_settings/{docId} { allow read, write: if isAdmin(); }
    match /product_sync_sources/{sourceId} { allow read, write: if isAdmin(); }
    match /scraped_products/{productId} { allow read, write: if isAdmin(); }
    match /price_history_log/{logId} { allow read, write: if isAdmin(); }
    match /sync_runs/{runId} { allow read, write: if isAdmin(); }

    match /notifications/{notifId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.userId || isClient(resource.data.userId)));
      allow create: if isAdminOrStaff() || (
        isAuthenticated()
        && request.resource.data.userId == 'admin'
        && (
          (
            request.resource.data.projectId is string
            && isClientOfProject(request.resource.data.projectId)
            && request.resource.data.type in ['change_request']
          )
          || (
            request.resource.data.clientId is string
            && isClient(request.resource.data.clientId)
            && request.resource.data.type == 'new_message'
          )
        )
      );
      allow update, delete: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.userId || isClient(resource.data.userId)));
    }

    // Public showcase, portfolio, products — readable by anyone
    match /showcase/{sceneId} { allow read: if true; allow write: if isAdmin(); }
    match /portfolio/{projId} { allow read: if true; allow write: if isAdmin(); }
    match /products/{prodId} { allow read: if true; allow write: if isAdmin(); }
    match /categories/{catId} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{testId} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /messages/{msgId} {
      allow read: if isAdminOrStaff() || (isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || isClient(resource.data.senderId) || isClient(resource.data.receiverId)));
      allow create: if isAdminOrStaff() || (isAuthenticated() && request.resource.data.senderId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /emails/{emailId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.to);
      allow write: if isAdmin();
      allow create: if request.resource.data.status == 'pending';
    }

    match /materials/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }

    match /work_orders/{id} { allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email); allow write: if isAdmin(); }
    match /containers/{id} { allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email); allow write: if isAdmin(); }
    match /transactions/{id} { allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email); allow write: if isAdmin(); }
    match /invoices/{id} {
      // Clients may read their own invoices — matched by clientId, email, OR project membership.
      // isClientOfProject() uses the project's clientIds array which contains all phone format
      // variants (+233, 233, 0...) so phone-auth users always match.
      allow read: if isAdmin()
        || isClient(resource.data.clientId)
        || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email)
        || (resource.data.projectId is string && isClientOfProject(resource.data.projectId))
        || (resource.data.parentId is string && isClientOfProject(resource.data.parentId));
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        (
          isClient(resource.data.clientId) ||
          (isAuthenticated() && resource.data.clientEmail == request.auth.token.email) ||
          (resource.data.projectId is string && isClientOfProject(resource.data.projectId))
        ) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'awaitingConfirmation', 'paymentMethodSubmitted', 'paymentSubmittedAt'
        ])
      );
    }
    match /tasks/{id} { allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email); allow write: if isAdmin(); }
    match /procurements/{id} { allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email); allow write: if isAdmin(); }
    match /activity_logs/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /approvals/{id} {
      allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isClient(resource.data.clientId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'clientNote', 'updatedAt'])
      );
    }
    match /notes/{id} { allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email); allow write: if isAdmin(); }
    match /media/{id} { allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email); allow write: if isAdmin(); }
    match /shipments/{id} { allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email); allow write: if isAdmin(); }
    match /renderingPackages/{id} {
      allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isClient(resource.data.clientId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedRevisions', 'approvedAt'])
      );
    }
    match /addOns/{id} {
      allow read: if isAdmin()
        || isClient(resource.data.clientId)
        || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email)
        || (resource.data.projectId is string && isClientOfProject(resource.data.projectId));
      allow write: if isAdmin();
    }

    // Logs written by Cloud Functions (Admin SDK bypasses rules, but good to have for reads)
    match /whatsapp_log/{id} { allow read: if isAdmin(); allow write: if false; }
    match /sms_log/{id} { allow read: if isAdmin(); allow write: if false; }
    match /whatsapp_inbox/{id} { allow read, write: if isAdmin(); }
    match /rate_limits/{id} { allow read, write: if false; } // Admin SDK only

    match /pendingPayments/{id} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true ||
        resource.data.uid == request.auth.uid
      );
      allow write: if false; // Cloud Function Admin SDK only
    }
    match /processedPayments/{id} {
      allow read: if request.auth.token.admin == true;
      allow write: if false;
    }

    // Change requests — clients can create for their own projects, admin manages
    match /change_requests/{id} {
      allow read: if isAdmin() || isClient(resource.data.clientId) || (isAuthenticated() && resource.data.clientEmail == request.auth.token.email);
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['projectId', 'clientId', 'status'])
        && request.resource.data.status == 'pending'
        && isClient(request.resource.data.clientId);
      allow update, delete: if isAdmin();
    }
  }
}
