rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Block all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == "admin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        authEmail().matches(".*@westlinefuture.com") ||
        authEmail() == "admin@westlinefuture.com"
      );
    }

    function isStaff() {
      return isAuthenticated() && (
        request.auth.token.role == "staff" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "staff"
      );
    }

    function isWorker() {
      return isAuthenticated() && (
        request.auth.token.role == "worker" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "worker"
      );
    }

    function isAdminOrStaff() {
      return isAdmin() || isStaff();
    }

    function authPhoneId() {
      return isAuthenticated() && request.auth.token.phone_number != null
        ? request.auth.token.phone_number.replace("+", "")
        : "";
    }

    function authEmail() {
      return isAuthenticated() && request.auth.token.email != null ? request.auth.token.email : "";
    }

    function isClient(clientId) {
      return isAuthenticated() && (
        request.auth.uid == clientId ||
        authPhoneId() == clientId ||
        authEmail().replace("@clients.westlinefuture.com", "") == clientId
      );
    }

    function isAssignedClient(data) {
      return isAuthenticated() && (
        isClient(data.clientId) ||
        isClient(data.primaryClientId) ||
        (data.clientIds is list && data.clientIds.hasAny([authPhoneId(), request.auth.uid]))
      );
    }

    function isAssignedWorker(data) {
      return isWorker() && data.assignedWorkers is list && data.assignedWorkers.hasAny([request.auth.uid]);
    }

    function isAssignedStaff(data) {
      return isStaff() && (
        (data.assignedStaff is list && data.assignedStaff.hasAny([request.auth.uid])) ||
        (data.assignedWorkers is list && data.assignedWorkers.hasAny([request.auth.uid])) ||
        data.assignedTo == request.auth.uid ||
        data.managerId == request.auth.uid
      );
    }

    function canReadProject(data) {
      return isAdmin() || isAssignedStaff(data) || isAssignedWorker(data) || isAssignedClient(data);
    }

    function canWriteProject(data) {
      return isAdmin() || isAssignedStaff(data);
    }

    function canWorkerUpdateProject(data) {
      return isAssignedWorker(data) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "stageId",
          "stageModel",
          "stageHistory",
          "progress",
          "status",
          "nextAction",
          "updatedAt"
        ]);
    }

    function canReadClientRecord(data) {
      return isAdminOrStaff() || isAssignedClient(data) || (isAuthenticated() && data.clientEmail == authEmail());
    }

    function canReadProjectLinkedRecord(data) {
      return isAdminOrStaff() ||
        isClient(data.clientId) ||
        isClient(data.primaryClientId) ||
        (data.clientIds is list && data.clientIds.hasAny([authPhoneId(), request.auth.uid]));
    }

    function isRenderingDocument(data) {
      return data.documentType == "rendering" || data.category == "rendering" || data.stageId == 3;
    }

    function canReadProjectDocument(projectData, documentData) {
      return isAdminOrStaff() ||
        isAssignedWorker(projectData) ||
        (
          isAssignedClient(projectData) &&
          documentData.clientVisible != false &&
          (
            !isRenderingDocument(documentData) ||
            projectData.renderingUnlocked == true ||
            projectData.renderingFeePaid == true
          )
        );
    }

    function canReadTopLevelDocument(data) {
      return isAdminOrStaff() ||
        (
          canReadProjectLinkedRecord(data) &&
          data.clientVisible != false &&
          (
            !isRenderingDocument(data) ||
            get(/databases/$(database)/documents/projects/$(data.projectId)).data.renderingUnlocked == true ||
            get(/databases/$(database)/documents/projects/$(data.projectId)).data.renderingFeePaid == true
          )
        );
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow get: if isAdminOrStaff() || isWorker() || (isAuthenticated() && (request.auth.uid == userId || isClient(userId)));
      allow list: if isAdminOrStaff();
      allow create: if isAdminOrStaff();
      allow update: if isAdminOrStaff() || (isAuthenticated() && (request.auth.uid == userId || isClient(userId)));
      allow delete: if isAdmin();
    }

    // --- OPERATIONS: JOBS & ASSETS ---
    match /jobs/{jobId} {
      allow read: if isAdminOrStaff();
      allow write: if isAdminOrStaff();
    }
    match /assets/{assetId} {
      allow read: if isAdminOrStaff();
      allow write: if isAdminOrStaff();
    }

    // --- PROJECTS & CLIENT DATA ---
    match /projects/{projectId} {
      allow get, list: if canReadProject(resource.data);
      allow create: if isAdminOrStaff();
      allow update: if canWriteProject(resource.data) || canWorkerUpdateProject(resource.data);
      allow delete: if isAdmin();

      match /documents/{docId} {
        allow get, list: if canReadProjectDocument(get(/databases/$(database)/documents/projects/$(projectId)).data, resource.data);
        allow create: if isAdminOrStaff() || isAssignedWorker(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow update, delete: if isAdminOrStaff();
      }

      match /{subcollection}/{docId} {
        allow get, list: if subcollection != "documents" && canReadProject(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create: if isAdminOrStaff() || (
          isAssignedWorker(get(/databases/$(database)/documents/projects/$(projectId)).data) &&
          subcollection in ["messages", "media", "notes"]
        ) || (
          isAssignedClient(get(/databases/$(database)/documents/projects/$(projectId)).data) &&
          subcollection in ["messages", "change_requests", "approvals"]
        );
        allow update: if isAdminOrStaff() || (
          subcollection == "messages" &&
          isAssignedClient(get(/databases/$(database)/documents/projects/$(projectId)).data) &&
          resource.data.senderId == request.auth.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "text", "editedAt", "editedBy", "editHistory", "updatedAt"
          ])
        );
        allow delete: if isAdmin();
      }
    }

    match /bookings/{bookingId} { allow read: if isAdminOrStaff(); allow create: if isAuthenticated(); }
    match /proposals/{proposalId} {
      allow read: if isAdminOrStaff() || isClient(resource.data.clientId);
      allow write: if isAdminOrStaff();
    }
    match /cms_content/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    
    match /notifications/{notifId} {
      allow read: if isAdminOrStaff() || (isAuthenticated() && (request.auth.uid == resource.data.userId || isClient(resource.data.userId)));
      allow create: if isAdminOrStaff() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdminOrStaff() || (isAuthenticated() && (request.auth.uid == resource.data.userId || isClient(resource.data.userId)));
    }

    match /portfolio/{projId} { allow read: if true; allow write: if isAdmin(); }
    match /products/{prodId} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{testId} { allow read: if true; allow create: if isAuthenticated(); allow update, delete: if isAdmin(); }

    match /messages/{msgId} {
      allow read: if isAdminOrStaff() || (isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || isClient(resource.data.senderId) || isClient(resource.data.receiverId)));
      allow create: if isAdminOrStaff() || (isAuthenticated() && request.resource.data.senderId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /showcase/{sceneId} { allow read: if true; allow write: if isAdmin(); }
    match /emails/{emailId} {
      allow read: if isAdminOrStaff() || (isAuthenticated() && authEmail() == resource.data.to);
      allow write: if isAdminOrStaff();
      allow create: if request.resource.data.keys().hasAll(["id", "from", "subject", "body", "type", "status", "date"]) &&
        request.resource.data.status == "Pending" &&
        request.resource.data.type in ["General Inquiry", "Marketplace Order", "Contact Inquiry"];
    }

    match /work_orders/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /containers/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /transactions/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /invoices/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /tasks/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /procurements/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /renderingPackages/{id} {
      allow read: if canReadProjectLinkedRecord(resource.data);
      allow create: if isAdminOrStaff();
      allow update: if isAdminOrStaff() || isClient(resource.data.clientId);
      allow delete: if isAdmin();
    }
    match /quotes/{id} {
      allow read: if canReadProjectLinkedRecord(resource.data);
      allow create: if isAdminOrStaff();
      allow update: if isAdminOrStaff() || isClient(resource.data.clientId);
      allow delete: if isAdmin();
    }
    match /addOns/{id} {
      allow read: if canReadProjectLinkedRecord(resource.data);
      allow create: if isAdminOrStaff() || (isAuthenticated() && isClient(request.resource.data.clientId));
      allow update: if isAdminOrStaff() || isClient(resource.data.clientId);
      allow delete: if isAdmin();
    }
    match /documents/{id} {
      allow read: if canReadTopLevelDocument(resource.data);
      allow create: if isAdminOrStaff() || isWorker();
      allow update, delete: if isAdminOrStaff();
    }
    match /activity_logs/{id} {
      allow read: if isAdminOrStaff();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    match /activityLogs/{id} {
      allow read: if isAdminOrStaff();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    match /approvals/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /change_requests/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /notes/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /media/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
    match /shipments/{id} { allow read: if canReadClientRecord(resource.data); allow write: if isAdminOrStaff(); }
  }
}
