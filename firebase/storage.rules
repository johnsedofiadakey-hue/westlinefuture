rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function authEmail() {
      return isAuthenticated() && request.auth.token.email != null ? request.auth.token.email : "";
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.matches(".*@westlinefuture\\.com") ||
        request.auth.token.email == "admin@westlinefuture.com"
      );
    }

    function isStaff() {
      return isAuthenticated() && request.auth.token.role == "staff";
    }

    function isWorker() {
      return isAuthenticated() && request.auth.token.role == "worker";
    }

    function isAdminOrStaff() {
      return isAdmin() || isStaff();
    }

    function isSafeUpload() {
      return request.resource.size < 20 * 1024 * 1024 &&
        request.resource.contentType.matches("image/.*|application/pdf|text/plain|application/vnd.openxmlformats-officedocument.*");
    }

    // User profile files
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Project media and documents — any authenticated user can upload (admin, staff, workers)
    match /projects/{projectId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if (isAdminOrStaff() || isWorker()) && isSafeUpload();
    }

    // Branding assets — admin only
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Field uploads — any authenticated user can upload (workers)
    match /field/{allPaths=**} {
      allow read: if isAdminOrStaff();
      allow write: if isAuthenticated() && isSafeUpload();
    }

    // CMS / showcase media
    match /cms/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Portfolio images
    match /portfolio/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
